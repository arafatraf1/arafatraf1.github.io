<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Rafi | CSE Student</title>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:      #0d1117;
      --surface: #161b22;
      --border:  #21262d;
      --accent:  #58a6ff;
      --text:    #e6edf3;
      --muted:   #8b949e;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Inter', sans-serif;
      line-height: 1.6;
      min-height: 100vh;
    }

    /* NAV */
    nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1.2rem 2rem;
      border-bottom: 1px solid var(--border);
      position: sticky;
      top: 0;
      background: rgba(13,17,23,0.92);
      backdrop-filter: blur(8px);
      z-index: 100;
    }
    .logo {
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 700;
      font-size: 1.1rem;
      color: var(--accent);
      text-decoration: none;
    }
    .nav-links { display: flex; gap: 1.8rem; list-style: none; }
    .nav-links a {
      color: var(--muted);
      text-decoration: none;
      font-size: 0.9rem;
      font-weight: 500;
      transition: color .2s;
    }
    .nav-links a:hover { color: var(--text); }

    /* HERO — side by side layout */
    .hero {
      max-width: 760px;
      margin: 0 auto;
      padding: 5rem 2rem 3rem;
      display: flex;
      align-items: center;
      gap: 3rem;
    }
    .hero-text { flex: 1; }
    .hero-photo {
      flex-shrink: 0;
      width: 160px;
      height: 160px;
      border-radius: 50%;
      overflow: hidden;
      border: 3px solid var(--border);
      background: var(--surface);
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .hero-photo img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    /* placeholder shown when no image is set */
    .hero-photo .placeholder {
      font-size: 4rem;
      line-height: 1;
    }
    .hero h1 {
      font-family: 'Space Grotesk', sans-serif;
      font-size: clamp(2rem, 5vw, 3rem);
      font-weight: 700;
      line-height: 1.15;
      margin-bottom: .8rem;
    }
    .hero h1 span { color: var(--accent); }
    .hero-subtitle {
      font-size: .9rem;
      font-weight: 600;
      color: var(--muted);
      letter-spacing: .04em;
      margin-bottom: .8rem;
    }
    .hero p {
      font-size: 1rem;
      color: var(--muted);
      max-width: 440px;
      margin-bottom: 1.8rem;
    }
    .btn-row { display: flex; gap: 1rem; flex-wrap: wrap; }
    .btn {
      display: inline-block;
      padding: .55rem 1.3rem;
      border-radius: 6px;
      font-size: .875rem;
      font-weight: 600;
      text-decoration: none;
      transition: opacity .2s, transform .15s;
    }
    .btn:hover { opacity: .85; transform: translateY(-1px); }
    .btn-primary { background: var(--accent); color: #0d1117; }
    .btn-ghost   { border: 1px solid var(--border); color: var(--text); }

    /* SECTIONS */
    section {
      max-width: 760px;
      margin: 0 auto;
      padding: 3.5rem 2rem;
      border-top: 1px solid var(--border);
    }
    .section-label {
      font-size: .75rem;
      font-weight: 600;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 1.2rem;
    }
    h2 {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 1.5rem;
      font-weight: 700;
      margin-bottom: 1rem;
    }

    /* COURSES / INTERESTS — simple list */
    .info-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      margin-top: 1rem;
    }
    .info-block h3 {
      font-family: 'Space Grotesk', sans-serif;
      font-size: .9rem;
      font-weight: 600;
      color: var(--accent);
      margin-bottom: .6rem;
    }
    .info-block ul {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: .35rem;
    }
    .info-block li {
      font-size: .875rem;
      color: var(--muted);
      padding-left: .9rem;
      position: relative;
    }
    .info-block li::before {
      content: '–';
      position: absolute;
      left: 0;
      color: var(--border);
    }

    /* SKILLS */
    .skills-grid {
      display: flex;
      flex-wrap: wrap;
      gap: .6rem;
      margin-top: 1rem;
    }
    .tag {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: .35rem .8rem;
      font-size: .82rem;
      color: var(--muted);
    }

    /* CONTACT */
    .contact-links { display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 1rem; }
    .contact-links a {
      display: flex;
      align-items: center;
      gap: .5rem;
      padding: .55rem 1.1rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 6px;
      text-decoration: none;
      font-size: .875rem;
      color: var(--text);
      transition: border-color .2s;
    }
    .contact-links a:hover { border-color: var(--accent); color: var(--accent); }

    /* FOOTER */
    footer {
      text-align: center;
      padding: 2rem;
      font-size: .8rem;
      color: var(--muted);
      border-top: 1px solid var(--border);
    }

    /* MOBILE */
    @media (max-width: 560px) {
      nav { padding: 1rem; }
      .nav-links { gap: 1rem; }
      .hero { flex-direction: column-reverse; align-items: flex-start; gap: 1.5rem; padding: 3rem 1.2rem 2rem; }
      .hero-photo { width: 110px; height: 110px; }
      section { padding: 2.5rem 1.2rem; }
      .info-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

